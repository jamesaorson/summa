{
    "version": 3,
    "configurePresets": [
        {
            "name": "_root-config",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "JAMESAORSON_TEMPLATE_CPP_BUILD_EXAMPLES": "ON",
                "JAMESAORSON_TEMPLATE_CPP_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "_root-config",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "_root-config",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "_root-build",
            "hidden": true,
            "jobs": 0
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "inherits": "_root-build"
        },
        {
            "name": "release",
            "configurePreset": "release",
            "inherits": "_root-build"
        }
    ],
    "testPresets": [
        {
            "name": "_test-base",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "debug",
            "inherits": "_test-base",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "inherits": "_test-base",
            "configurePreset": "release"
        }
    ],
    "workflowPresets": [
        {
            "name": "debug",
            "steps": [
                { "type": "configure", "name": "debug" },
                { "type": "build", "name": "debug" },
                { "type": "test", "name": "debug" }
            ]
        },
        {
            "name": "release",
            "steps": [
                { "type": "configure", "name": "release" },
                { "type": "build", "name": "release" },
                { "type": "test", "name": "release" }
            ]
        }
    ]
}
